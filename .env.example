# Frontend
PUBLIC_APP_BASE_URL=https://your-vercel-domain.vercel.app

# Neon database
NEON_DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require
DEV_NEON_DATABASE_URL=postgresql://<user>:<password>@<dev-neon-host>/<db>?sslmode=require
PROD_NEON_DATABASE_URL=postgresql://<user>:<password>@<prod-neon-host>/<db>?sslmode=require

# API behavior
SIGNED_URL_TTL_SECONDS=3600
FULL_YAML_TEXT_MAX=5000
AUTH_ENABLED=true
SIMPLE_AUTH_USERNAME=teacher
SIMPLE_AUTH_PASSWORD=change_me_now

# Runtime backend selectors (kept for compatibility; should remain neon/blob)
DATA_BACKEND=neon
FILE_BACKEND=blob

# Vercel Blob storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
# Optional: set if storing blob object keys instead of absolute URLs
BLOB_PUBLIC_BASE_URL=https://<store-id>.public.blob.vercel-storage.com

# Local script tooling
# Optional path override when pg_dump/pg_restore are not on PATH
PG_BIN_DIR=C:\Program Files\PostgreSQL\17\bin
# Optional backup output folder
BACKUP_DIR=./backups
