# Frontend
PUBLIC_APP_BASE_URL=https://your-vercel-domain.vercel.app

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres direct connection string (Dashboard -> Project Settings -> Database -> Connection string)
# Used by local tooling like scripts/backup_supabase_db.py (keep private; do not expose in frontend builds)
SUPABASE_DB_URL=postgresql://postgres:<YOUR_PASSWORD>@db.<YOUR_PROJECT_REF>.supabase.co:5432/postgres

# API behavior
SIGNED_URL_TTL_SECONDS=3600
FULL_YAML_TEXT_MAX=5000
AUTH_ENABLED=true
SIMPLE_AUTH_USERNAME=teacher
SIMPLE_AUTH_PASSWORD=change_me_now

# Provider switches (supabase -> neon/blob migration)
DATA_BACKEND=supabase
FILE_BACKEND=supabase

# Neon target (when DATA_BACKEND=neon)
NEON_DATABASE_URL=postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require

# Vercel Blob target (when FILE_BACKEND=blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
# Optional: set if storing blob object keys instead of absolute URLs
BLOB_PUBLIC_BASE_URL=https://<store-id>.public.blob.vercel-storage.com
