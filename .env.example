# Frontend
PUBLIC_APP_BASE_URL=https://your-vercel-domain.vercel.app

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API behavior
SIGNED_URL_TTL_SECONDS=3600
FULL_YAML_TEXT_MAX=5000

# Google ICS sync (cron endpoint + script)
GCAL_ICS_URL=https://calendar.google.com/calendar/ical/.../basic.ics
GCAL_EVENT_KEY_PREFIX=gcal_evt_
GCAL_SYNC_STATUS_KEY=gcal_sync_status
GCAL_SYNC_PAST_DAYS=30
GCAL_SYNC_FUTURE_DAYS=365
SYNC_HTTP_TIMEOUT_SEC=20
SYNC_CRON_TOKEN=replace-with-random-long-secret
